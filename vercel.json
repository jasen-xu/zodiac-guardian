{
  "version": 2,
  "builds": [
    {
      "src": "server/server.js",
      "use": "@vercel/node"
    },
    {
      "src": "index.html",
      "use": "@vercel/static"
    },
    {
      "src": "guardian.html",
      "use": "@vercel/static"
    },
    {
      "src": "fortune.html",
      "use": "@vercel/static"
    },
    {
      "src": "liuyao.html",
      "use": "@vercel/static"
    },
    {
      "src": "caishen.html",
      "use": "@vercel/static"
    },
    {
      "src": "caishen-bei.html",
      "use": "@vercel/static"
    },
    {
      "src": "caishen-dong.html",
      "use": "@vercel/static"
    },
    {
      "src": "caishen-nan.html",
      "use": "@vercel/static"
    },
    {
      "src": "caishen-xi.html",
      "use": "@vercel/static"
    },
    {
      "src": "caishen-zhong.html",
      "use": "@vercel/static"
    },
    {
      "src": "wuxing.html",
      "use": "@vercel/static"
    },
    {
      "src": "wuxing-jin.html",
      "use": "@vercel/static"
    },
    {
      "src": "wuxing-mu.html",
      "use": "@vercel/static"
    },
    {
      "src": "wuxing-shui.html",
      "use": "@vercel/static"
    },
    {
      "src": "wuxing-huo.html",
      "use": "@vercel/static"
    },
    {
      "src": "wuxing-tu.html",
      "use": "@vercel/static"
    },
    {
      "src": "wenchuang.html",
      "use": "@vercel/static"
    },
    {
      "src": "dongfangjing-renju.html",
      "use": "@vercel/static"
    },
    {
      "src": "dongfangjing-zuting.html",
      "use": "@vercel/static"
    },
    {
      "src": "css/**",
      "use": "@vercel/static"
    },
    {
      "src": "js/**",
      "use": "@vercel/static"
    },
    {
      "src": "assets/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server/server.js"
    },
    {
      "src": "/index\\.html",
      "dest": "/index.html"
    },
    {
      "src": "/guardian\\.html",
      "dest": "/guardian.html"
    },
    {
      "src": "/fortune\\.html",
      "dest": "/fortune.html"
    },
    {
      "src": "/liuyao\\.html",
      "dest": "/liuyao.html"
    },
    {
      "src": "/caishen\\.html",
      "dest": "/caishen.html"
    },
    {
      "src": "/caishen-(bei|dong|nan|xi|zhong)\\.html",
      "dest": "/caishen-$1.html"
    },
    {
      "src": "/wuxing\\.html",
      "dest": "/wuxing.html"
    },
    {
      "src": "/wuxing-(jin|mu|shui|huo|tu)\\.html",
      "dest": "/wuxing-$1.html"
    },
    {
      "src": "/wenchuang\\.html",
      "dest": "/wenchuang.html"
    },
    {
      "src": "/dongfangjing-renju\\.html",
      "dest": "/dongfangjing-renju.html"
    },
    {
      "src": "/dongfangjing-zuting\\.html",
      "dest": "/dongfangjing-zuting.html"
    },
    {
      "src": "/(css|js|assets)/(.*)",
      "dest": "/$1/$2"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
